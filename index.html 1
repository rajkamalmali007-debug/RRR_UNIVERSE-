<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RRR Universe - Trading Community</title>

<style>

/* RESET */
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
scroll-behavior:smooth;
}

/* BACKGROUND */
body{
background: radial-gradient(circle at top, #0d1b2a, #000000, #05070d);
color:white;
overflow-x:hidden;
}

/* FLOATING GOLD LIGHTS */
body::before,
body::after{
content:"";
position:fixed;
width:300px;
height:300px;
background:gold;
filter:blur(140px);
opacity:0.15;
z-index:-1;
animation:float 6s infinite alternate;
}

body::before{
top:10%;
left:10%;
}

body::after{
bottom:10%;
right:10%;
}

@keyframes float{
from{transform:translate(0,0);}
to{transform:translate(80px,-80px);}
}

/* SHINING TEXT */
.glow-text{
color:gold;
font-weight:bold;
text-shadow:
0 0 5px #ffd700,
0 0 10px #ffd700,
0 0 20px #ffcc00,
0 0 40px #ffcc00;
animation:shine 2.5s infinite alternate;
}

@keyframes shine{
0%{filter:brightness(1);}
100%{filter:brightness(1.8);}
}

/* NAVBAR */
nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:15px 30px;
background:rgba(0,0,0,0.6);
backdrop-filter:blur(10px);
position:fixed;
width:100%;
top:0;
z-index:1000;
border-bottom:1px solid #222;
}

nav h2{
color:gold;
}

nav a{
color:white;
margin:0 12px;
text-decoration:none;
font-size:14px;
}

nav a:hover{
color:gold;
}

/* HERO */
.hero{
height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
}

.hero h1{
font-size:55px;
}

.hero p{
color:#aaa;
margin-top:10px;
}

/* BUTTON */
.btn{
margin-top:20px;
padding:12px 25px;
border:none;
background:linear-gradient(90deg,gold,#ffcc00);
color:black;
font-weight:bold;
border-radius:8px;
cursor:pointer;
transition:0.3s;
}

.btn:hover{
transform:scale(1.1);
box-shadow:0 0 20px gold;
}

/* SECTIONS */
section{
padding:80px 20px;
text-align:center;
}

.card{
background:rgba(255,255,255,0.05);
border:1px solid rgba(255,215,0,0.2);
border-left:4px solid gold;
padding:20px;
margin:15px auto;
width:80%;
border-radius:12px;
backdrop-filter:blur(10px);
transition:0.3s;
}

.card:hover{
transform:scale(1.03);
box-shadow:0 0 20px gold;
}

/* CHART */
.chart{
width:90%;
margin:auto;
height:450px;
border-radius:10px;
overflow:hidden;
}

/* FOOTER */
footer{
padding:20px;
text-align:center;
color:#777;
border-top:1px solid #222;
}

</style>
</head>

<body>

<!-- NAVBAR -->
<nav>
<h2>RRR Universe</h2>
<div>
<a href="#about">About</a>
<a href="#features">Features</a>
<a href="#market">Market</a>
<a href="#join">Join</a>
</div>
</nav>

<!-- HERO -->
<div class="hero">
<h1 class="glow-text">RRR Universe</h1>
<p class="glow-text">Elite Trading & Investment Community</p>
<button class="btn" onclick="join()">Join Now</button>
</div>

<!-- ABOUT -->
<section id="about">
<h2 class="glow-text">About Us</h2>
<div class="card">
We help beginners learn Forex, Crypto & Stock Market with simple strategies and daily updates.
</div>
</section>

<!-- FEATURES -->
<section id="features">
<h2 class="glow-text">Why Join Us</h2>
<div class="card">📊 Daily Market Analysis</div>
<div class="card">🧠 Beginner Friendly Learning</div>
<div class="card">🚀 Trading Signals & Updates</div>
<div class="card">💬 Private Community Access</div>
</section>

<!-- MARKET -->
<section id="market">
<h2 class="glow-text">Live Market</h2>

<div class="chart">
<iframe 
src="https://www.tradingview.com/embed-widget/advanced-chart/?symbol=NASDAQ:AAPL"
width="100%" height="100%" frameborder="0">
</iframe>
</div>

</section>

<!-- JOIN -->
<section id="join">
<h2 class="glow-text">Join Community</h2>
<div class="card">
Instagram: @rrr_universe_<br><br>
<button class="btn" onclick="join()">Join Now</button>
</div>
</section>

<!-- FOOTER -->
<footer>
© 2026 RRR Universe | All Rights Reserved
</footer>

<script>
function join(){
window.open("https://instagram.com/rrr_universe_","_blank");
}
</script>

</body>
</html>
